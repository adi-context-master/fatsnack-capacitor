{
  "name": "fatsnack-capacitor",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor wrapper that ships the fat-snag Next.js simulator screens as a native iOS and Android app.",
  "scripts": {
    "build:web": "node scripts/build-web.mjs",
    "sync": "cap sync",
    "build": "npm run build:web && npm run sync",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "run:ios": "cap run ios",
    "run:android": "cap run android",
    "add:ios": "cap add ios",
    "add:android": "cap add android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.0",
    "@capacitor/core": "^7.4.0",
    "@capacitor/ios": "^7.4.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  }
}
